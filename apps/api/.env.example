# Skopiuj ten plik do .env i uzupełnij wartości:
#   cp .env.example .env

# Klucz API do Claude (NIGDY nie wrzucaj go na GitHuba!)
ANTHROPIC_API_KEY=sk-ant-...

# Model. Domyślnie zgodnie z architekturą projektu.
# Aby oszczędzać budżet, możesz użyć: claude-sonnet-4-6 lub claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-opus-4-8

# Przełącznik RAG:
#   false -> WERSJA PODSTAWOWA (ocena 4): wiedza tylko z knowledge/general.md
#   true  -> WERSJA ROZSZERZONA (ocena 5): bot szuka też w repozytorium SWPS
RAG_ENABLED=false

# Port backendu (frontend woła http://localhost:5001/chat)
PORT=5001
